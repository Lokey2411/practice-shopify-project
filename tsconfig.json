{
	"compilerOptions": {
		"module": "commonjs",
		"esModuleInterop": true,
 		"allowSyntheticDefaultImports": true,
		"target": "es6",
		"moduleResolution": "node",
		"sourceMap": true,
		"outDir": "dist",
		"baseUrl": "./",
		"paths": {
		  	"@/*": ["./src/*"],
			"@config/*": ["src/config/*"],
			"@model/*": ["src/model/*"],
			"@service/*": ["src/service/*"],
			"@controller/*": ["src/controller/*"],
			"@router/*": ["src/router/*"],
			"@middleware/*": ["src/middleware/*"],
			"@utils/*": ["src/utils/*"]
		}
	},
	"include": [
		"src"
	],
	"exclude": [
		"node_modules",
		"dist"
	],
	"lib": ["es2015"]
}
